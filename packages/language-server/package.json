{
  "name": "@vellum-docs/language-server",
  "type": "module",
  "version": "0.2.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/photon-hq/vellum.git",
    "directory": "packages/language-server"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "vellum-language-server": "./dist/server.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/server.ts --format esm --out-dir dist --dts",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vellum-docs/core": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
