{
  "publisher": "photon-hq",
  "name": "vellum-vscode",
  "displayName": "Vellum",
  "version": "0.1.1",
  "private": true,
  "description": "Language support for Vellum documentation templates (.vel files)",
  "repository": {
    "type": "git",
    "url": "https://github.com/photon-hq/vellum.git",
    "directory": "packages/vscode"
  },
  "categories": ["Programming Languages"],
  "main": "./dist/extension.mjs",
  "engines": {
    "vscode": "^1.85.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "vel",
        "aliases": ["Vellum"],
        "extensions": [".vel"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "vel-md",
        "aliases": ["Vellum (Markdown)"],
        "filenamePatterns": ["*.md.vel"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "vel-mdx",
        "aliases": ["Vellum (MDX)"],
        "filenamePatterns": ["*.mdx.vel"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "vel-html",
        "aliases": ["Vellum (HTML)"],
        "filenamePatterns": ["*.html.vel"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vel",
        "scopeName": "text.html.markdown.vel",
        "path": "./syntaxes/vel-md.tmLanguage.json"
      },
      {
        "language": "vel-md",
        "scopeName": "text.html.markdown.vel",
        "path": "./syntaxes/vel-md.tmLanguage.json"
      },
      {
        "language": "vel-mdx",
        "scopeName": "text.html.markdown.vel.mdx",
        "path": "./syntaxes/vel-mdx.tmLanguage.json"
      },
      {
        "language": "vel-html",
        "scopeName": "text.html.vel",
        "path": "./syntaxes/vel-html.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Vellum",
      "properties": {
        "vellum.configPath": {
          "type": "string",
          "default": "",
          "description": "Path to vellum.config.ts (relative to workspace root). Auto-detected if empty."
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown src/extension.ts --format esm --out-dir dist --external vscode",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.6.3"
  }
}
