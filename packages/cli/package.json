{
  "name": "@vellum-docs/cli",
  "type": "module",
  "version": "0.2.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/photon-hq/vellum.git",
    "directory": "packages/cli"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "vellum": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "pnpm build",
    "build": "tsdown src/index.ts src/bin.ts --format esm --out-dir dist --dts",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vellum-docs/core": "workspace:*",
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
