{
  "name": "@vellum-docs/cli",
  "type": "module",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/qwerzl/vellum-docs.git",
    "directory": "packages/cli"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vellum": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vellum-docs/core": "workspace:*",
    "jiti": "^2.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
