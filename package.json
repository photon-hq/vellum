{
  "name": "vellum-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Vellum — a language-agnostic documentation preprocessor",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "example": "turbo run build --filter=vellum-example-basic",
    "example:nextjs": "turbo run docs:build --filter=vellum-example-nextjs"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
